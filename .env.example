# ── Supabase — persistent storage (Sprint 2+) ─────────────────────────────────
# Required in production (Railway). When set, SQLite is bypassed entirely.
# Obtain from: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key

# ── Database — local development only ─────────────────────────────────────────
# Only used when SUPABASE_URL is NOT set (i.e. local dev / CI without Supabase).
# Not required on Railway.
DATABASE_PATH=./data/bookshop.db

# ── Books API ─────────────────────────────────────────────────────────────────
# No authentication required — CORS open
BOOKS_API_BASE_URL=https://pthcjxgnaycbjrlsjhbt.supabase.co/functions/v1/public-books-api
BOOKS_API_TIMEOUT=60

# ── Google Search Console — OAuth 2.0 ────────────────────────────────────────
# Obtain these by running: python scripts/gsc_oauth_setup.py
# See docs/gsc_oauth_setup.md for step-by-step instructions.

# OAuth 2.0 Desktop client credentials (from Google Cloud Console)
GSC_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GSC_OAUTH_CLIENT_SECRET=GOCSPX-your-client-secret

# Long-lived refresh token — generated once by gsc_oauth_setup.py
# Store in Railway Variables, never in .env or git
GSC_OAUTH_REFRESH_TOKEN=1//your-refresh-token

# The site URL exactly as registered in Google Search Console
# Include trailing slash for URL-prefix properties
GSC_SITE_URL=https://bookshopnearme.lk/

# Days to look back when collecting (agent fills in any missing dates automatically)
GSC_LOOKBACK_DAYS=7

# ── Application ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development

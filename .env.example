# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_PATH=./data/bookshop.db

# ── Books API ─────────────────────────────────────────────────────────────────
# No authentication required — CORS open
BOOKS_API_BASE_URL=https://pthcjxgnaycbjrlsjhbt.supabase.co/functions/v1/public-books-api
BOOKS_API_TIMEOUT=60

# ── Google Search Console ─────────────────────────────────────────────────────
# LOCAL DEV: path to your service account JSON file
GSC_CREDENTIALS_PATH=/path/to/gsc-service-account.json

# RAILWAY / PRODUCTION: base64-encoded service account JSON (no file needed)
# Generate with: base64 -i gsc-service-account.json | tr -d '\n'
# Set this in the Railway dashboard under Variables — do not put it in .env
GSC_CREDENTIALS_B64=

# The site URL exactly as registered in Google Search Console
# Include trailing slash for URL-prefix properties
GSC_SITE_URL=https://bookshopnearme.lk/

# Days to look back when collecting (agent fills in any missing dates automatically)
GSC_LOOKBACK_DAYS=7

# ── Application ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development
